{
  "icon": "assets/images/icon.png",
  "name": "flutter-explorer",
  "displayName": "Flutter Explorer",
  "description": "Custom snippets",
  "publisher": "amirasake",
  "author": {
    "name": "Amir Asake",
    "email": "amir.asakeev.r@gmail.com",
    "url": "https://www.linkedin.com/in/amirasake/"
  },
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ho1yspirt/flutter_explorer.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.createBloc",
        "title": ": New Bloc"
      },
      {
        "command": "extension.createFeatureFolder",
        "title": ": New Feature"
      },
      {
        "command": "extension.createFetchBloc",
        "title": ": New Fetch Bloc"
      },
      {
        "command": "extension.createScreen",
        "title": ": New Screen"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.createBloc",
          "when": "explorerResourceIsFolder",
          "group": "flutterExplorerGroup@1"
        },
        {
          "command": "extension.createFeatureFolder",
          "when": "explorerResourceIsFolder",
          "group": "flutterExplorerGroup@1"
        },
        {
          "command": "extension.createFetchBloc",
          "when": "explorerResourceIsFolder",
          "group": "flutterExplorerGroup@1"
        },
        {
          "command": "extension.createScreen",
          "when": "explorerResourceIsFolder",
          "group": "flutterExplorerGroup@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.1",
    "typescript": "^5.5.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1"
  }
}